+#
+# Based on linux/samples/bpf/Makefile
+#
+
 # kbuild trick to avoid linker error. Can be omitted if a module is built.
 obj- := dummy.o
 
@@ -21,12 +25,31 @@ always := $(hostprogs-y)
 always += bpf/extfuse.o
 
